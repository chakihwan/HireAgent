# PostgreSQL
POSTGRES_PASSWORD=changeme

# API 키 암호화 키 (필수 — 기본값/빈값/잘못된 Fernet 키면 백엔드 기동 차단)
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# CORS 허용 origin (콤마 구분). 배포 시 실제 프론트 도메인으로 변경.
CORS_ORIGINS=http://localhost:3000

# Ollama
# docker-compose 내에서 백엔드는 http://ollama:11434 (내부 네트워크) 자동 사용
# 호스트에서 직접 접근: http://localhost:11435
OLLAMA_HOST_PORT=11435

# ── GPU 가속 (선택) ──────────────────────────────────────────────
# NVIDIA GPU + nvidia-container-toolkit이 있으면 아래 줄의 주석을 해제하세요.
# 그러면 `docker compose up`만으로 GPU override(docker-compose.gpu.yml)가 자동 병합됩니다.
#   - Ollama 추론 GPU 가속 + VRAM 초과 모델 사전 경고 활성화
# Mac(Apple Silicon)·AMD·CPU 환경은 주석 그대로 두세요 (Docker는 CPU 모드).
#   - Mac M칩은 Metal GPU + 통합 메모리로 강력하지만, Docker Desktop은
#     Metal passthrough 미지원 → 컨테이너에선 못 씀. 네이티브 Ollama(brew) 설치 시 Metal 가속 (ADR-014)
#   - VRAM 경고는 NVIDIA(NVML)만 지원 → Mac/AMD는 graceful 비활성화 (크래시 없음)
# COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml
